# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database - use a managed Postgres URL from Supabase, Neon, or Vercel Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docmind

# Auth - production deployments must keep these in platform env vars.
AUTH_SECRET=replace-with-a-32-byte-random-secret
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# AI / embeddings - only required once real retrieval is wired.
OPENAI_API_KEY=replace-with-server-side-key
